  el.classList.add('active');
}

// CANVAS CINEMÁTICA
const CC=()=>document.getElementById('cine-canvas');
let cineAnim=null,cineTrail=[];
function updateCineVal(){
  document.getElementById('cv0-val').textContent=document.getElementById('cv0').value+' m/s';
  document.getElementById('cang-val').textContent=document.getElementById('cang').value+'°';
  document.getElementById('cgrav-val').textContent=document.getElementById('cgrav').value+' m/s²';
}
function drawCineStatic(){
  const c=CC(),ctx=c.getContext('2d');
  c.width=c.offsetWidth||800;
  drawCineGround(ctx,c.width,c.height);
}
function drawCineGround(ctx,w,h){
  ctx.fillStyle='#060d1a';ctx.fillRect(0,0,w,h);
  ctx.strokeStyle='#1e3a5f';ctx.lineWidth=1;
  for(let i=0;i<w;i+=40){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,h);ctx.stroke();}
  for(let j=0;j<h;j+=40){ctx.beginPath();ctx.moveTo(0,j);ctx.lineTo(w,j);ctx.stroke();}
  ctx.fillStyle='#1e3a5f';ctx.fillRect(0,h-30,w,30);
  ctx.fillStyle='#2d5a3d';ctx.fillRect(0,h-32,w,4);
}
function launchProjectile(){
  cancelAnimationFrame(cineAnim);cineTrail=[];
  const c=CC();c.width=c.offsetWidth||800;
  const W=c.width,H=c.height,ctx=c.getContext('2d');
  const v0=+document.getElementById('cv0').value;
  const ang=+document.getElementById('cang').value*Math.PI/180;
  const g=+document.getElementById('cgrav').value;
  const vx=v0*Math.cos(ang),vy=v0*Math.sin(ang);
  const T=2*vy/g,R=vx*T,Hmax=vy*vy/(2*g);
  const scale=Math.min((W-60)/Math.max(R,1),(H-80)/Math.max(Hmax,1))*0.85;
  const ox=40,oy=H-32;
  document.getElementById('stat-alcance').textContent=R.toFixed(1)+' m';
  document.getElementById('stat-hmax').textContent=Hmax.toFixed(1)+' m';
  document.getElementById('stat-tvoo').textContent=T.toFixed(2)+' s';
  document.getElementById('stat-vx').textContent=vx.toFixed(1)+' m/s';
  document.getElementById('stat-vy').textContent=vy.toFixed(1)+' m/s';
  let t=0,dt=T/120;
  function frame(){
    ctx.clearRect(0,0,W,H);drawCineGround(ctx,W,H);
    ctx.beginPath();ctx.strokeStyle='#1e3a5f44';ctx.lineWidth=2;ctx.setLineDash([4,4]);
    for(let tt=0;tt<=T;tt+=T/80){const px=ox+vx*tt*scale,py=oy-(vy*tt-0.5*g*tt*tt)*scale;tt===0?ctx.moveTo(px,py):ctx.lineTo(px,py);}
    ctx.stroke();ctx.setLineDash([]);
    const px=ox+vx*t*scale,py=oy-(vy*t-0.5*g*t*t)*scale;
    cineTrail.push({x:px,y:py});
    if(cineTrail.length>2){
      ctx.beginPath();
      const grd=ctx.createLinearGradient(cineTrail[0].x,cineTrail[0].y,px,py);
      grd.addColorStop(0,'#00d4ff00');grd.addColorStop(1,'#00d4ffcc');
      ctx.strokeStyle=grd;ctx.lineWidth=3;
      ctx.moveTo(cineTrail[0].x,cineTrail[0].y);
      cineTrail.forEach(p=>ctx.lineTo(p.x,p.y));ctx.stroke();
    }
    const grd2=ctx.createRadialGradient(px,py,1,px,py,10);
    grd2.addColorStop(0,'#fff');grd2.addColorStop(1,'#00d4ff');
    ctx.beginPath();ctx.arc(px,py,10,0,Math.PI*2);ctx.fillStyle=grd2;ctx.fill();
    const vxt=vx,vyt=vy-g*t;
    ctx.beginPath();ctx.strokeStyle='#f59e0b';ctx.lineWidth=2.5;
    ctx.moveTo(px,py);ctx.lineTo(px+vxt*3,py-vyt*3);ctx.stroke();
    ctx.fillStyle='#94a3b8';ctx.font='12px monospace';
    ctx.fillText(`t=${t.toFixed(2)}s  x=${(vx*t).toFixed(1)}m  y=${Math.max(0,vy*t-0.5*g*t*t).toFixed(1)}m`,10,20);
    t+=dt;
    if(t<=T+dt) cineAnim=requestAnimationFrame(frame);
    else{
      ctx.beginPath();ctx.arc(ox+R*scale,oy,8,0,Math.PI*2);ctx.fillStyle='#10b981';ctx.fill();
      ctx.fillStyle='#10b981';ctx.font='bold 12px monospace';
      ctx.fillText('R='+R.toFixed(1)+'m',ox+R*scale-20,oy-14);
    }
  }
  frame();
}
function resetProjectile(){
  cancelAnimationFrame(cineAnim);cineTrail=[];
  ['stat-alcance','stat-hmax','stat-tvoo','stat-vx','stat-vy'].forEach(id=>document.getElementById(id).textContent='—');
  drawCineStatic();
}

// CANVAS DINÂMICA
const DC=()=>document.getElementById('dina-canvas');
let dinaAnim=null;
function updateDinaVal(){
  document.getElementById('dF-val').textContent=document.getElementById('dF').value+' N';
  document.getElementById('dm-val').textContent=document.getElementById('dm').value+' kg';
  document.getElementById('dmu-val').textContent=(document.getElementById('dmu').value/100).toFixed(2);
}
function drawDinaStatic(){
  const c=DC(),ctx=c.getContext('2d');
  c.width=c.offsetWidth||800;
  drawDinaFrame(ctx,c.width,c.height,80,0,0);
}
function drawDinaFrame(ctx,W,H,bx,vel,t){
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#060d1a';ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#1e3a5f';ctx.fillRect(0,H-40,W,40);
  ctx.fillStyle='#2d5a3d';ctx.fillRect(0,H-43,W,4);
  const bw=70,bh=55,by=H-43-bh;
  const grd=ctx.createLinearGradient(bx,by,bx+bw,by+bh);
  grd.addColorStop(0,'#3b82f6');grd.addColorStop(1,'#1d4ed8');
  ctx.fillStyle=grd;ctx.fillRect(bx,by,bw,bh);
  ctx.strokeStyle='#60a5fa';ctx.lineWidth=2;ctx.strokeRect(bx,by,bw,bh);
  ctx.fillStyle='#fff';ctx.font='bold 13px monospace';ctx.textAlign='center';
  ctx.fillText(document.getElementById('dm').value+'kg',bx+bw/2,by+bh/2+5);ctx.textAlign='left';
  const F=+document.getElementById('dF').value;
  if(F>0){
    const aL=Math.min(F*0.8,120);
    ctx.beginPath();ctx.strokeStyle='#f59e0b';ctx.lineWidth=4;
    ctx.moveTo(Math.max(10,bx-aL),by+bh/2);ctx.lineTo(bx,by+bh/2);ctx.stroke();
    ctx.beginPath();ctx.fillStyle='#f59e0b';
    ctx.moveTo(bx,by+bh/2);ctx.lineTo(bx-12,by+bh/2-8);ctx.lineTo(bx-12,by+bh/2+8);ctx.fill();
    ctx.fillStyle='#f59e0b';ctx.font='bold 12px monospace';
    ctx.fillText('F='+F+'N',Math.max(10,bx-aL),by+bh/2-12);
  }
  ctx.beginPath();ctx.strokeStyle='#a78bfa';ctx.lineWidth=2;
  ctx.moveTo(bx+bw/2,by);ctx.lineTo(bx+bw/2,by-35);ctx.stroke();
  ctx.fillStyle='#a78bfa';ctx.font='11px monospace';ctx.fillText('N',bx+bw/2+4,by-20);
  ctx.beginPath();ctx.strokeStyle='#f87171';ctx.lineWidth=2;
  ctx.moveTo(bx+bw/2,by+bh);ctx.lineTo(bx+bw/2,by+bh+35);ctx.stroke();
  ctx.fillStyle='#f87171';ctx.fillText('mg',bx+bw/2+4,by+bh+25);
  if(vel>0){
    const mu=document.getElementById('dmu').value/100,m=document.getElementById('dm').value;
    const fat=(mu*m*10).toFixed(0);
    ctx.beginPath();ctx.strokeStyle='#ef4444';ctx.lineWidth=3;
    ctx.moveTo(bx+bw,by+bh-8);ctx.lineTo(bx+bw+50,by+bh-8);ctx.stroke();
    ctx.fillStyle='#ef4444';ctx.font='11px monospace';ctx.fillText('f='+fat+'N',bx+bw+4,by+bh-12);
  }
  ctx.fillStyle='#94a3b8';ctx.font='12px monospace';
  ctx.fillText(`v = ${vel.toFixed(1)} m/s  |  t = ${t.toFixed(1)} s`,16,22);
}
function startDina(){
  cancelAnimationFrame(dinaAnim);
  const c=DC();c.width=c.offsetWidth||800;
  const W=c.width,H=c.height,ctx=c.getContext('2d');
  const F=+document.getElementById('dF').value,m=+document.getElementById('dm').value;
  const mu=document.getElementById('dmu').value/100,fat=mu*m*10;
  const a=(F-fat)/m,fn=m*10;
  document.getElementById('d-acel').textContent=a.toFixed(2)+' m/s²';
  document.getElementById('d-fat').textContent=fat.toFixed(1)+' N';
  document.getElementById('d-fn').textContent=fn.toFixed(1)+' N';
  if(a<=0){drawDinaFrame(ctx,W,H,80,0,0);document.getElementById('d-vel').textContent='0 (estático)';return;}
  let bx=80,vel=0,t=0;
  function frame(){
    vel+=a/60;t+=1/60;bx+=vel*20/60;
    document.getElementById('d-vel').textContent=vel.toFixed(1)+' m/s';
    drawDinaFrame(ctx,W,H,bx,vel,t);
    if(bx<W-80) dinaAnim=requestAnimationFrame(frame);
  }
  frame();
}
function resetDina(){
  cancelAnimationFrame(dinaAnim);
  ['d-acel','d-fat','d-fn','d-vel'].forEach(id=>document.getElementById(id).textContent='—');
  drawDinaStatic();
}

// CALCULADORAS
function calcMRU(){
  const s=((+document.getElementById('mru-s0').value||0)+(+document.getElementById('mru-v').value)*(+document.getElementById('mru-t').value));
  document.getElementById('mru-res-val').textContent=s.toFixed(2)+' m';
  document.getElementById('mru-result').style.display='block';
}
function calcMRUV(){
  const s0=+document.getElementById('mruv-s0').value||0,v0=+document.getElementById('mruv-v0').value;
  const a=+document.getElementById('mruv-a').value,t=+document.getElementById('mruv-t').value;
  document.getElementById('mruv-s').textContent=(s0+v0*t+.5*a*t*t).toFixed(2)+' m';
  document.getElementById('mruv-v').textContent=(v0+a*t).toFixed(2)+' m/s';
  document.getElementById('mruv-result').style.display='block';
}
function calcObliquo(){
  const v0=+document.getElementById('ob-v0').value,ang=+document.getElementById('ob-ang').value*Math.PI/180;
  const g=+document.getElementById('ob-g').value||9.8;
  document.getElementById('ob-r').textContent=(v0*v0*Math.sin(2*ang)/g).toFixed(2)+' m';
  document.getElementById('ob-h').textContent=(v0*v0*Math.sin(ang)**2/(2*g)).toFixed(2)+' m';
  document.getElementById('ob-t').textContent=(2*v0*Math.sin(ang)/g).toFixed(2)+' s';
  document.getElementById('ob-result').style.display='block';
}
function calcN2(){
  const fv=document.getElementById('n2-f').value,mv=document.getElementById('n2-m').value,av=document.getElementById('n2-a').value;
  if([fv,mv,av].filter(v=>v==='').length!==1){alert('Deixe exatamente um campo vazio!');return;}
  let res,label;
  if(fv===''){res=(+mv)*(+av);label='Força F (N)';}
  else if(mv===''){res=(+fv)/(+av);label='Massa m (kg)';}
  else{res=(+fv)/(+mv);label='Aceleração a (m/s²)';}
  document.getElementById('n2-res-label').textContent=label;
  document.getElementById('n2-res-val').textContent=res.toFixed(3);
  document.getElementById('n2-result').style.display='block';
}
function calcAtrito(){
  const mu=+document.getElementById('at-mu').value,m=+document.getElementById('at-m').value;
  const g=+document.getElementById('at-g').value||10,fn=m*g;
  document.getElementById('at-fn').textContent=fn.toFixed(1)+' N';
  document.getElementById('at-fat').textContent=(mu*fn).toFixed(1)+' N';
  document.getElementById('at-result').style.display='block';
}

window.addEventListener('load',()=>{drawCineStatic();drawDinaStatic();updateCineVal();updateDinaVal();});
window.addEventListener('resize',()=>{drawCineStatic();drawDinaStatic();});
</script>
