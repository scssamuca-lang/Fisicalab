  el.classList.add('active');
  document.body.classList.toggle('nivel-es',lvl==='es');
}
function toggleSol(btn){
  const sol=btn.nextElementSibling;
  sol.classList.toggle('show');
  btn.textContent=sol.classList.contains('show')?'Ocultar Resolução':'Ver Resolução';
}
function filterEx(tab,topic,el){
  const container=document.getElementById(`${tab}-ex`);
  container.querySelectorAll('.exercise').forEach(ex=>{
    ex.classList.toggle('ex-hidden', topic!=='todos' && ex.dataset.topic!==topic);
  });
